# 服务端口
PORT=3001

# JWT 签名密钥（生产环境请使用随机字符串，至少 32 位）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# 数据库连接（PostgreSQL）
# 本地开发：docker compose up -d postgres
DATABASE_URL="postgresql://xiaoyuantong:xiaoyuantong_dev@localhost:5432/xiaoyuantong"

# 前端地址（CORS 白名单）
CLIENT_URL=http://localhost:5173

# API 速率限制（每分钟最大请求数/每 IP）
RATE_LIMIT_MAX=100

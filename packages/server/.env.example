# 服务端口
PORT=3001

# JWT 签名密钥（生产环境必须修改！）
JWT_SECRET=change-me-in-production

# 数据库连接（Railway 会自动注入 DATABASE_URL）
# 本地开发连接 Docker PostgreSQL：docker compose up -d postgres
DATABASE_URL="postgresql://xiaoyuantong:xiaoyuantong_dev@localhost:5432/xiaoyuantong"

# 前端地址（CORS 白名单，Vercel 部署后更新）
CLIENT_URL=http://localhost:5173